generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./feps-events.db"
}

enum Role {
  EDITOR
  MANAGER
  SUPERADMIN
}

model EventCategory {
  id      String  @id @default(cuid())
  nameEn  String
  nameAr  String
  nameFr  String
  color   String  @default("#1A3A6E")
  bg      String  @default("rgba(26,58,110,0.12)")
  
  events  Event[]
}

model AuditLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  action     String
  userId     String?
  entityType String?  // e.g. "EVENT", "USER"
  entityId   String?
  details    String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model User {
  id        String   @id @default(cuid())
  name      String   
  email     String   @unique 
  password  String
  role        Role     @default(EDITOR)
  permissions String?  @default("[\"events:create\"]")
  createdAt   DateTime @default(now())

  auditLogs AuditLog[]
}

model Event {
  id                    String    @id @default(cuid())
  title                 String
  titleAr               String?
  titleFr               String?
  categoryId            String
  category              EventCategory @relation(fields: [categoryId], references: [id])
  startDate             DateTime
  endDate               DateTime?
  location              String?
  locationAr            String?
  locationFr            String?
  description           String?
  descriptionAr         String?
  descriptionFr         String?
  agendaText            String?
  agendaTextAr          String?
  agendaTextFr          String?
  agendaFile            String?   // stored filepath
  imageUrl              String?   // stored filepath
  published             Boolean   @default(false)
  status                String    @default("ACTIVE") // ACTIVE | ARCHIVED
  reportSummary         String?   // ملخص الفعالية
  reportResults         String?   // النتائج والمخرجات
  reportRecommendations String?   // التوصيات
  reportCustomFields    String?   // JSON array of {title, content}
  surveyQuestions       String?   // JSON array of {id, type, text, options}
  surveyEnabled         Boolean   @default(false) // Whether the survey is currently open
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  surveyResponses SurveyResponse[]
}

model SurveyResponse {
  id        String   @id @default(cuid())
  eventId   String
  answers   String   // JSON of { questionId: string, answer: string }
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TriviaCategory {
  id        String   @id @default(cuid())
  nameEn    String
  nameAr    String
  nameFr    String
  color     String   @default("#1A3A6E")
  bg        String   @default("rgba(26,58,110,0.12)")
  createdAt DateTime @default(now())

  questions TriviaQuestion[]
}

model TriviaQuestion {
  id            String   @id @default(cuid())
  categoryId    String?
  textEn        String
  textAr        String
  textFr        String
  options       String   // JSON: [{textEn, textAr, textFr, isCorrect}]
  explanation   String?  // Optional fun fact shown after answering
  explanationAr String?
  explanationFr String?
  createdAt     DateTime @default(now())

  category TriviaCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
