generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./feps-events.db"
}

enum Role {
  EDITOR
  MANAGER
  SUPERADMIN
}

enum EventType {
  CULTURAL
  SCIENTIFIC
  LITERARY
  HONORS
  GRADUATION_PROJECT
  VISIT
  SEMINAR
  WORKSHOP
  PRACTICAL_TRAINING
  EXHIBITION
  CONFERENCE
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  action    String
  userId    String?
  details   String?

  user User? @relation(fields: [userId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String   
  email     String   @unique 
  password  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  auditLogs AuditLog[]
}

model Event {
  id          String    @id @default(cuid())
  title       String
  titleAr     String?
  titleFr     String?
  type        EventType
  startDate   DateTime
  endDate     DateTime?
  location    String?
  description String?
  agendaText  String?
  agendaFile  String?   // stored filepath
  imageUrl    String?   // stored filepath
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
